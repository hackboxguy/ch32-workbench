---
BasedOnStyle:           LLVM
IndentWidth:            4
UseTab:                 Never
ColumnLimit:            100
AllowShortFunctionsOnASingleLine: None
AlignConsecutiveMacros: AcrossEmptyLines
# SortIncludes off so tooling cannot break the include-order contract
# in boards/board.h: apps MUST #include "ch32fun.h" before "board.h".
SortIncludes:           false
# Keep braces on the same line as the control statement, matching ch32fun.
BreakBeforeBraces:      Attach
# Don't auto-indent preprocessor directives inside #if blocks; the v1
# board.h umbrella uses leading-space-after-hash style we want to keep.
IndentPPDirectives:     None
...
